	"content": [
		{
			"id": "focus-styling",
			"title": "Focus",
			"type": "accordion-container",
			"content": [
				{
"id": "focus-message",
				"type": "message",
				"text": "Focus styles are critical for keyboard navigation and accessibility. Set your default focus styles here. You can also change focus color locally by setting a new value for <code>--focus-color</code> on any element."
				},
				{
					"id": "focus-style",
					"title": "Focus Style",
					"type": "select",
					"default": "outline",
					"options": [
						"outline",
						"shadow"
					],
					"tooltip": "The default focus style for your website.",
					"documentation": "https://automaticcss.com/docs/global-focus-styling/"
				},
				{
					"id": "focus-color",
					"title": "Focus Color",
					"type": "text",
					"default": "var(--primary)",
					"target": "a",
					"tooltip": "The default focus color for focusable elements."
				},
				{
					"id": "focus-width",
					"title": "Focus Width",
					"type": "text",
					"default": "2px",
					"target": "a",
					"tooltip": "The thickness of the focus border."
				},
				{
					"id": "focus-offset",
					"title": "Focus Offset",
					"type": "text",
					"default": "2px",
					"target": "a",
					"tooltip": "The space between the focus border and the focused element.",
					"displayWhen": [
						"focus-style",
						"outline"
					]
				}
			]
		},
		{
			"id": "scroll-offsets",
			"title": "Scroll Offsets",
			"type": "accordion-container",
			"content": [
				{
					"id": "offsets-message",
					"type": "message",
					"text": "<a target='_blank' href='https://automaticcss.com/docs/scroll-offsets/'>Scroll Offsets</a> prevent elements from colliding with the device edge when scrolling to hash links."
				},
				{
					"id": "scroll-margin-max",
					"title": "Scroll Offset (Desktop)",
					"type": "px",
					"default": 0,
					"percentage-convert": true,
					"tooltip": "The amount of scroll offset on desktop devices.",
					"documentation": "https://automaticcss.com/docs/scroll-offsets/"
				},
				{
					"id": "scroll-margin-min",
					"title": "Scroll Offset (Mobile)",
					"type": "px",
					"default": 0,
					"percentage-convert": true,
					"tooltip": "The amount of scroll offset on mobile devices.",
					"documentation": "https://automaticcss.com/docs/scroll-offsets/"
				}
			]
		},
		{
			"id": "sticky-styling",
			"title": "Sticky Styling",
			"type": "accordion-container",
			"content": [
				{
					"id": "sticky-message",
					"type": "message",
					"text": "Set default offsets for sticky elements and choose whether sticky elements should automatically offset based on your site's header height (requires you to set header height values in Layout)."
				},
				{
					"id": "option-sticky-offset",
					"title": "Offset Sticky Automatically",
					"type": "toggle",
					"default": "on",
					"tooltip": "Automatically offset elements that use the .sticky class to prevent header collisions."
				},
				{
					"id": "sticky-offset-custom",
					"title": "Custom Sticky Offset",
					"type": "text",
					"default": "60px",
					"displayWhen": [
						"option-sticky-offset",
						"off"
					]
				}
			]
		},
		{
			"id": "blockquote-styling",
			"title": "Blockquotes",
			"type": "accordion-container",
			"content": [
				{
					"id": "blockquote-message",
					"type": "message",
					"text": "Configure default styling for blockquote elements, including the main blockquote, footer, and cite elements."
				},
				{
					"id": "blockquote-main-section",
					"type": "section-container",
					"title": "Main",
					"documentation": "https://docs.automaticcss.com/elements/blockquotes/",
					"displayWhen": [
						"option-blockquote-styling",
						"on"
					],
					"content": [
						{
							"id": "blockquote-padding",
							"title": "Padding",
							"type": "text",
							"default": "var(--space-m)",
							"skip-if-empty": true,
							"tooltip": "The padding around the blockquote content.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-gap",
							"title": "Gap",
							"type": "text",
							"default": "1em",
							"skip-if-empty": true,
							"tooltip": "The gap between the blockquote content.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-border-width",
							"title": "Border Width",
							"type": "text",
							"default": "0 0 0 3px",
							"skip-if-empty": true,
							"tooltip": "The width of the blockquote border. Accepts standard CSS border-width values.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-border-style",
							"title": "Border Style",
							"type": "text",
							"default": "solid",
							"skip-if-empty": true,
							"tooltip": "The style of the blockquote border (e.g., solid, dashed, dotted).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-border-color",
							"title": "Border Color",
							"type": "text",
							"default": "var(--primary)",
							"skip-if-empty": true,
							"tooltip": "The color of the blockquote border.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-radius",
							"title": "Border Radius",
							"type": "text",
							"default": "var(--radius)",
							"cssVariable": "--blockquote-border-radius",
							"skip-if-empty": true,
							"tooltip": "The border radius of the blockquote, creating rounded corners.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-background",
							"title": "Background",
							"type": "text",
							"default": "var(--neutral-ultra-light)",
							"skip-if-empty": true,
							"tooltip": "The background color or gradient of the blockquote.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-box-shadow",
							"title": "Box Shadow",
							"type": "text",
							"default": "none",
							"skip-if-empty": true,
							"tooltip": "The box shadow effect for the blockquote.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-max-width",
							"title": "Max Width",
							"type": "text",
							"default": "",
							"cssVariable": "--blockquote-max-inline-size",
							"skip-if-empty": true,
							"tooltip": "The maximum width of the blockquote. When set, the blockquote will not exceed this width.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						}
					]
				},
				{
					"id": "blockquote-text-section",
					"type": "section-container",
					"title": "Text",
					"documentation": "https://docs.automaticcss.com/elements/blockquotes/",
					"displayWhen": [
						"option-blockquote-styling",
						"on"
					],
					"content": [
						{
							"id": "blockquote-text-color",
							"title": "Color",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The text color of the blockquote content.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-text-font-family",
							"title": "Font Family",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The font family for the blockquote text.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-text-font-style",
							"title": "Font Style",
							"type": "text",
							"default": "normal",
							"skip-if-empty": true,
							"tooltip": "The font style for the blockquote (e.g., normal, italic, oblique).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-text-font-size",
							"title": "Font Size",
							"type": "text",
							"default": "var(--text-l)",
							"skip-if-empty": true,
							"tooltip": "The font size of the blockquote text.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-text-font-weight",
							"title": "Font Weight",
							"type": "text",
							"default": "normal",
							"skip-if-empty": true,
							"tooltip": "The font weight of the blockquote text (e.g., normal, bold, 400, 700).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-text-line-height",
							"title": "Line Height",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The line height (leading) of the blockquote text.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-text-align",
							"title": "Text Align",
							"type": "text",
							"default": "left",
							"skip-if-empty": true,
							"tooltip": "The text alignment of the blockquote (e.g., left, center, right, justify).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-text-transform",
							"title": "Text Transform",
							"type": "text",
							"default": "none",
							"skip-if-empty": true,
							"tooltip": "The text transformation applied to the blockquote (e.g., none, uppercase, lowercase, capitalize).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						}
					]
				},
				{
					"id": "blockquote-footer-section",
					"type": "section-container",
					"title": "Footer & Caption",
					"documentation": "https://docs.automaticcss.com/elements/blockquotes/",
					"displayWhen": [
						"option-blockquote-styling",
						"on"
					],
					"content": [
						{
							"id": "blockquote-footer-padding",
							"title": "Padding",
							"type": "text",
							"default": "0",
							"skip-if-empty": true,
							"tooltip": "The padding around the blockquote footer & caption content.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-margin-block",
							"title": "Margin",
							"type": "text",
							"default": "1em 0",
							"skip-if-empty": true,
							"tooltip": "The margin around the blockquote footer & caption content.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-font-family",
							"title": "Font Family",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The font family for the blockquote footer & caption text.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-font-size",
							"title": "Font Size",
							"type": "text",
							"default": "var(--text-s)",
							"skip-if-empty": true,
							"tooltip": "The font size of the blockquote footer & caption text.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-font-weight",
							"title": "Font Weight",
							"type": "text",
							"default": "normal",
							"skip-if-empty": true,
							"tooltip": "The font weight of the blockquote footer & caption text (e.g., normal, bold, 400, 700).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-font-style",
							"title": "Font Style",
							"type": "text",
							"default": "normal",
							"skip-if-empty": true,
							"tooltip": "The font style for the blockquote footer & caption (e.g., normal, italic, oblique).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-line-height",
							"title": "Line Height",
							"type": "text",
							"default": "1.5",
							"skip-if-empty": true,
							"tooltip": "The line height (leading) of the blockquote footer & caption text.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-text-transform",
							"title": "Text Transform",
							"type": "text",
							"default": "none",
							"skip-if-empty": true,
							"tooltip": "The text transformation applied to the blockquote footer & caption (e.g., none, uppercase, lowercase, capitalize).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-footer-color",
							"title": "Color",
							"type": "text",
							"default": "currentColor",
							"skip-if-empty": true,
							"tooltip": "The text color of the blockquote footer & caption.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						}
					]
				},
				{
					"id": "blockquote-cite-section",
					"type": "section-container",
					"title": "Cite",
					"documentation": "https://docs.automaticcss.com/elements/blockquotes/",
					"displayWhen": [
						"option-blockquote-styling",
						"on"
					],
					"content": [
						{
							"id": "blockquote-cite-font-family",
							"title": "Font Family",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The font family for the blockquote cite element.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-cite-font-size",
							"title": "Font Size",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The font size of the blockquote cite element.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-cite-font-weight",
							"title": "Font Weight",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The font weight of the blockquote cite text (e.g., normal, bold, 400, 700).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-cite-font-style",
							"title": "Font Style",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The font style for the blockquote cite (e.g., normal, italic, oblique).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-cite-line-height",
							"title": "Line Height",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The line height (leading) of the blockquote cite text.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-cite-text-transform",
							"title": "Text Transform",
							"type": "text",
							"default": "inherit",
							"skip-if-empty": true,
							"tooltip": "The text transformation applied to the blockquote cite (e.g., none, uppercase, lowercase, capitalize).",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "blockquote-cite-color",
							"title": "Color",
							"type": "text",
							"default": "currentColor",
							"skip-if-empty": true,
							"tooltip": "The text color of the blockquote cite element.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						}
					]
				},
				{
					"id": "blockquote-options-section",
					"type": "section-container",
					"title": "Options",
					"documentation": "https://docs.automaticcss.com/elements/blockquotes/",
					"content": [
						{
							"id": "option-blockquote-styling",
							"title": "Blockquote Styling",
							"type": "toggle",
							"default": "on",
							"tooltip": "Enable blockquote styling. When off, blockquote variables and styles will not be loaded.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/"
						},
						{
							"id": "option-auto-style-blockquotes",
							"title": "Auto Style Blockquotes",
							"type": "toggle",
							"default": "on",
							"tooltip": "Automatically style blockquote elements. When off, only elements with the .blockquote class will be styled.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/",
							"displayWhen": [
								"option-blockquote-styling",
								"on"
							]
						},
						{
							"id": "blockquote-selector-exclusions",
							"title": "Exclude Selectors",
							"type": "textarea",
							"default": ":is([class*='-card'] blockquote, figure[class*='-card'], figure[class*='-card'] blockquote)",
							"skip-if-empty": true,
							"output": "quotes",
							"tooltip": "Comma-separated list of selectors to exclude from blockquote styling. These blockquotes will not receive automatic styling.",
							"documentation": "https://docs.automaticcss.com/elements/blockquotes/",
							"displayWhen": [
								["option-blockquote-styling", "on"],
								["option-auto-style-blockquotes", "on"]
							]
						}
					]
				}
			]
		},
		{
			"id": "selection-styling",
			"title": "Selection Styling",
			"type": "accordion-container",
			"content": [
				{
					"id": "selection-message",
					"type": "message",
					"text": "Selection styling is the styling of text that is selected/highlighted by the user (like when you're going to copy text to your clipboard)."
				},
				{
					"id": "selection-bg",
					"title": "Background Color",
					"type": "text",
					"default": "",
					"skip-if-empty": true,
					"cssVariable": "--selection-bg-color",
					"validation": {
						"required": false
					},
					"tooltip": "The background color of user-selected text on your website.",
					"documentation": "https://automaticcss.com/docs/selection-styling/"
				},
				{
					"id": "selection-text",
					"title": "Text Color",
					"type": "text",
					"default": "",
					"skip-if-empty": true,
					"cssVariable": "--selection-text-color",
					"validation": {
						"required": false
					},
					"tooltip": "The text color of user-selected text on your website.",
					"documentation": "https://automaticcss.com/docs/selection-styling/"
				},
				{
					"id": "selection-bg-alt",
					"title": "Alt Background Color",
					"type": "text",
					"default": "",
					"skip-if-empty": true,
					"cssVariable": "--selection-bg-color-alt",
					"validation": {
						"required": false
					},
					"tooltip": "The alternate background color of user-selected text on your website.",
					"documentation": "https://automaticcss.com/docs/selection-styling/"
				},
				{
					"id": "selection-text-alt",
					"title": "Alt Text Color",
					"type": "text",
					"default": "",
