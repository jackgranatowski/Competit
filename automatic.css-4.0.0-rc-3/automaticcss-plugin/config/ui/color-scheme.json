			"type": "section-container",
			"tooltip": "",
			"description": "What color scheme are you designing the site in?",
			"content": [
				{
					"id": "color-scheme-message",
					"type": "message",
					"text": "Add support for dark/light mode. You can set the scheme and then choose to implement the inversion manually or automatically."
				},
{
				"id": "auto-color-scheme",
				"title": "Enable Color Scheme Support",
				"type": "toggle",
				"default": "off",
				"tooltip": "Automatically convert all colors and shades to light-dark and enable the use of color scheme utilities."
			},
			{
			"id": "option-ref-color-tokens",
			"title": "Generate Reference Color Tokens",
			"type": "toggle",
			"default": "off",
			"tooltip": "Generate reference color tokens (--primary-ref, --primary-light-ref, etc.) that don't use light-dark(). Use these to manually compose light-dark() values with different color combinations.",
			"displayWhen": ["auto-color-scheme", "on"]
			},
			{
				"id": "website-color-scheme",
					"title": "Website Scheme",
					"type": "select",
					"default": "light only",
					"options": ["normal", "light dark", "light only", "dark only"],
					"tooltip": "Is your main scheme primarily light or dark?",
					"documentation": "https://automaticcss.com/docs/color-scheme-dark-mode/"
				}
			]
		},
